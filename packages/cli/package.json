{
  "name": "@mcp-craftsman/cli",
  "version": "0.2.0",
  "private": false,
  "description": "CLI for generating and validating MCP Craftsman projects.",
  "type": "module",
  "bin": {
    "mcp-craftsman": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "test": "vitest run"
  },
  "dependencies": {
    "@mcp-craftsman/core": "workspace:^",
    "@mcp-craftsman/node": "workspace:^",
    "cosmiconfig": "^9.0.2",
    "typescript": "^5.8.3"
  }
}
