{
  "workspaces": {
    "packages/cli": {
      "entry": [
        "src/cli.ts",
        "src/index.ts",
        "test/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "ignoreDependencies": [
        "@mcp-craftsman/core",
        "@mcp-craftsman/node"
      ]
    },
    "packages/core": {
      "entry": [
        "src/index.ts",
        "test/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ]
    },
    "packages/node": {
      "entry": [
        "src/index.ts",
        "test/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "ignoreDependencies": []
    },
    "packages/zod": {
      "entry": [
        "src/index.ts",
        "test/**/*.ts"
      ],
      "project": [
        "src/**/*.ts",
        "test/**/*.ts"
      ],
      "ignoreDependencies": [
        "@mcp-craftsman/core"
      ]
    }
  }
}
